default_environment: default
environments:
    default:
        connections:
            postgres:
                - name: oltp
                  username: $POSTGRES_USER
                  password: $POSTGRES_PASSWORD
                  host: $POSTGRES_HOST
                  port: $POSTGRES_PORT
                  database: $POSTGRES_DB
                  schema: public
            duckdb:
                - name: olap
                  path: $DUCKDB_FILE_PATH
